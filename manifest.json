{
  "manifest_version": 3,
  "name": "Retail AdCopy",
  "version": "1.9",
  "version_name": "1.9 (Sweeps ticket type)",
  "description": "Retail AdCopy Team Time Tracking with Process selection and shared OneDrive folder sync",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Retail AdCopy",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R"
      },
      "description": "Open Retail AdCopy"
    }
  }
}
